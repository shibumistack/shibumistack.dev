# Deployment configuration
# DEPLOY_HOST is the SSH config host alias (e.g., "alpha") or hostname
# DEPLOY_USER is the SSH user on the server
# DEPLOY_PATH is the absolute path to the project on the server
# DEPLOY_SSH_KEY is the path to the SSH private key (optional if using SSH config)
# DEPLOY_CONTAINER_CMD is "podman-compose" (default), "docker", or "podman"

DEPLOY_HOST=your-server.example.com
DEPLOY_USER=root
DEPLOY_PATH=/opt/shibumistack.dev
# DEPLOY_SSH_KEY=~/.ssh/id_rsa
# DEPLOY_CONTAINER_CMD=podman-compose
